@page
@model EstacionamientoR.Pages.Account.RegisterModel

<div class="auth-container">

    <div class="auth-card register-card">

        <div class="text-center mb-4">

            <div class="logo-circle">
                👤
            </div>

            <h2 class="mt-3 fw-bold">
                Crear Cuenta
            </h2>

            <p class="text-muted">
                Regístrate para usar el sistema
            </p>

        </div>

        <form method="post">

            <div class="mb-3">

                <label>Nombre</label>

                <input asp-for="Usuario.Nombre"
                       class="form-control custom-input"/>

            </div>

            <div class="mb-3">

                <label>Correo</label>

                <input asp-for="Usuario.Correo"
                       class="form-control custom-input"/>

            </div>

            <div class="mb-3">

                <label>Contraseña</label>

                <input asp-for="Usuario.Password"
                       type="password"
                       class="form-control custom-input"/>

            </div>

            <div class="mb-4">

                <label>Rol</label>

                <select asp-for="Usuario.Rol"
                        class="form-select custom-input">

                    <option value="Cliente">
                        Cliente
                    </option>

                </select>

            </div>

            <button type="submit"
                    class="btn btn-register w-100">

                Registrarme

            </button>

        </form>

        <hr>

        <div class="text-center">

            <a asp-page="/Account/Login"
               class="login-link">

                Ya tengo cuenta

            </a>

        </div>

    </div>

</div>

<style>

:root{
    --uv-blue:#18529D;
    --uv-green:#28AD56;
}

.auth-container{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

    background:
    linear-gradient(
        135deg,
        #18529D,
        #28AD56
    );
}

.register-card{
    width:500px;
}

.auth-card{
    background:white;
    padding:40px;
    border-radius:25px;

    box-shadow:
    0 20px 50px rgba(0,0,0,.2);
}

.logo-circle{
    width:90px;
    height:90px;

    background:
    linear-gradient(
        135deg,
        #18529D,
        #28AD56
    );

    color:white;
    border-radius:50%;

    display:flex;
    align-items:center;
    justify-content:center;

    margin:auto;

    font-size:40px;
}

.custom-input{
    border-radius:12px;
    padding:12px;
}

.btn-register{
    background:#28AD56;
    color:white;
    border:none;
    font-weight:bold;
    padding:12px;
    border-radius:12px;
}

.btn-register:hover{
    background:#209148;
}

.login-link{
    color:#18529D;
    text-decoration:none;
    font-weight:bold;
}

</style>