@page
@model EstacionamientoR.Pages.Account.LoginModel

<div class="auth-container">

    <div class="auth-card">

        <div class="text-center mb-4">

            <div class="logo-circle">
                🎃
            </div>

            <h2 class="mt-3 fw-bold">
                Iniciar Sesión
            </h2>

            <p class="text-muted">
                Sistema de Gestión de Estacionamientos
            </p>

        </div>

        <form method="post">

            <div class="mb-3">

                <label class="form-label">
                    Correo Electrónico
                </label>

                <input asp-for="Correo"
                       class="form-control custom-input" />

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Contraseña
                </label>

                <input asp-for="Password"
                       type="password"
                       class="form-control custom-input" />

            </div>

            <button type="submit"
                    class="btn btn-login w-100">

                Ingresar

            </button>

        </form>

        <hr>

        <div class="text-center">

            <span>
                ¿No tienes cuenta?
            </span>

            <a asp-page="/Account/Register"
               class="register-link">

                Registrarse

            </a>

        </div>

    </div>

</div>

<style>

:root{
    --uv-blue:#18529D;
    --uv-green:#28AD56;
}

.auth-container{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;

    background:
    linear-gradient(
        135deg,
        #18529D,
        #28AD56
    );
}

.auth-card{
    width:420px;
    background:white;
    padding:40px;
    border-radius:25px;

    box-shadow:
    0 20px 50px rgba(0,0,0,.2);
}

.logo-circle{
    width:90px;
    height:90px;

    background:
    linear-gradient(
        135deg,
        #18529D,
        #28AD56
    );

    color:white;

    border-radius:50%;

    display:flex;
    align-items:center;
    justify-content:center;

    margin:auto;

    font-size:40px;
}

.custom-input{
    border-radius:12px;
    padding:12px;
}

.custom-input:focus{
    border-color:#18529D;
    box-shadow:0 0 0 .2rem rgba(24,82,157,.2);
}

.btn-login{
    background:#18529D;
    color:white;
    font-weight:bold;
    border:none;
    padding:12px;
    border-radius:12px;
}

.btn-login:hover{
    background:#144480;
}

.register-link{
    color:#28AD56;
    font-weight:bold;
    text-decoration:none;
}

.register-link:hover{
    color:#1e8742;
}

</style>