@page
@model EstacionamientoR.Pages.Admin.Espacios.CreateModel

<div class="container mt-4">

    <div class="card shadow p-4">

        <h2 class="mb-4">
            Nuevo Espacio
        </h2>

        <form method="post">

            <div class="mb-3">

                <label class="form-label">
                    Número
                </label>

                <input asp-for="Espacio.NumeroEspacio"
                       class="form-control" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Tipo
                </label>

                <select asp-for="Espacio.Tipo"
                        class="form-select">

                    <option>Auto</option>
                    <option>Moto</option>
                    <option>Discapacitado</option>

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Estado
                </label>

                <select asp-for="Espacio.Estado"
                        class="form-select">

                    <option>Disponible</option>
                    <option>Ocupado</option>
                    <option>Reservado</option>
                    <option>FueraServicio</option>

                </select>

            </div>

            <button class="btn btn-success">

                Guardar

            </button>

            <a asp-page="Index"
               class="btn btn-secondary">

                Volver

            </a>

        </form>

    </div>

</div>