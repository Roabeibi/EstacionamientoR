@page
@model EstacionamientoR.Pages.Admin.Espacios.IndexModel

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-4">

        <h2>
            Administración de Espacios
        </h2>

        <a asp-page="Create"
           class="btn btn-primary">

            Nuevo Espacio

        </a>

    </div>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>Número</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Acciones</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model.Espacios)
            {
                <tr>

                    <td>@item.NumeroEspacio</td>

                    <td>@item.Tipo</td>

                    <td>@item.Estado</td>

                    <td>

                        <a asp-page="Edit"
                           asp-route-id="@item.Id"
                           class="btn btn-warning btn-sm">

                            Editar

                        </a>

                        <a asp-page="Delete"
                           asp-route-id="@item.Id"
                           class="btn btn-danger btn-sm">

                            Eliminar

                        </a>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>