@page
@model EstacionamientoR.Pages.Admin.Trabajadores.IndexModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            Gestión de Trabajadores
        </h2>

        <a asp-page="/Admin/Trabajadores/Create"
           class="btn btn-success">

            <i class="fa fa-plus"></i>
            Nuevo Trabajador

        </a>

    </div>

    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead class="table-primary">

                    <tr>

                        <th>Nombre</th>

                        <th>Correo</th>

                        <th>Sucursal</th>

                        <th>Fecha Registro</th>

                        <th>Acciones</th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model.Trabajadores)
                    {
                        <tr>

                            <td>
                                @item.Nombre
                            </td>

                            <td>
                                @item.Correo
                            </td>

                            <td>

                                @if(string.IsNullOrEmpty(item.NombreEstacionamiento))
                                {
                                    <span class="badge bg-secondary">
                                        Sin asignar
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @item.NombreEstacionamiento
                                    </span>
                                }

                            </td>

                            <td>
                                @item.FechaRegistro.ToString("dd/MM/yyyy")
                            </td>

                            <td>

                                <a asp-page="/Admin/Trabajadores/AsignarSucursal"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">

                                    <i class="fa fa-building"></i>

                                    Cambiar

                                </a>

                                <a asp-page="/Admin/Trabajadores/Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">

                                    <i class="fa fa-trash"></i>

                                    Eliminar

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>