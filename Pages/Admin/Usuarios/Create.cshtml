@page
@model EstacionamientoR.Pages.Admin.Usuarios.CreateModel
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<h2>Crear Usuario</h2>

<form method="post">

    <div class="mb-3">
        <label>Nombre</label>
        <input asp-for="Usuario.Nombre" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Correo</label>
        <input asp-for="Usuario.Correo" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Contraseña</label>
        <input asp-for="Usuario.Password"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Rol</label>
        <select asp-for="Usuario.Rol"
                class="form-control">
            <option>Trabajador</option>
            <option>Cliente</option>
            <option>Admin</option>
        </select>
    </div>

    <button class="btn btn-primary">
        Guardar Usuario
    </button>

</form>