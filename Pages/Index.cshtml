<!-- =========================
     ESTILOS
========================= -->

<style>

    /* VARIABLES */
    :root {
        --uv-azul: #18529D;
        --uv-verde: #28AD56;
    }

/* =========================
   FONDO GLOBAL
========================= */

html,
body {
    min-height: 100%;
    margin: 0;
    padding: 0;
}

body {
    background: linear-gradient(
        270deg,
        #18529D,
        #123d75,
        #28AD56
    );
    background-size: 600% 600%;
    animation: gradientMove 12s ease infinite;
}

/* HERO */

.hero-section {
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background: transparent;
}

/* ANIMACIÓN */

@@keyframes gradientMove {
    0% {
        background-position: 0% 50%;
    }

    50% {
        background-position: 100% 50%;
    }

    100% {
        background-position: 0% 50%;
    }
}

    @@keyframes gradientMove {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    /* OVERLAY */
    .overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.25);
    }

    /* PARTICLES */
    .particles {
        position: absolute;
        width: 100%;
        height: 100%;
        z-index: 0;
    }

    .particles::before {
        content: "";
        position: absolute;
        width: 200%;
        height: 200%;
        background-image: radial-gradient(
            circle,
            rgba(255, 255, 255, 0.15) 2px,
            transparent 2px
        );
        background-size: 50px 50px;
        animation: moveParticles 30s linear infinite;
        opacity: 0.25;
    }

    @@keyframes moveParticles {
        from {
            transform: translateY(0);
        }

        to {
            transform: translateY(-600px);
        }
    }

    /* HERO CONTENT */
    .hero-content {
        position: relative;
        z-index: 2;
    }

    /* IMAGE */
    .hero-image {
        border-radius: 25px;
        max-height: 500px;
        object-fit: cover;
        border: 5px solid rgba(255, 255, 255, 0.2);
        animation: float 4s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-12px);
        }

        100% {
            transform: translateY(0);
        }
    }

    /* FEATURE CARDS */
    .feature-card {
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 20px;
        text-align: center;
        transition: 0.4s;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .feature-card:hover {
        transform: translateY(-12px) scale(1.05);
        background: rgba(255, 255, 255, 0.18);
    }

    /* BUTTONS */
    .btn-uv-primary {
        background: var(--uv-verde);
        color: white;
        border-radius: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-uv-primary:hover {
        transform: translateY(-4px);
        background: #1f8c45;
    }

    .btn-uv-secondary {
        border: 2px solid white;
        color: white;
        border-radius: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

    .btn-uv-secondary:hover {
        background: white;
        color: var(--uv-azul);
        transform: translateY(-4px);
    }

    /* BADGE */
    .badge-uv {
        background: var(--uv-verde);
        color: white;
        border-radius: 10px;
    }

    /* =========================
       SCROLL REVEAL (NUEVO)
    ========================= */

    .reveal-left,
    .reveal-right,
    .reveal-item {
        opacity: 0;
    }

    .reveal-left.show {
        animation: fadeLeft 1s ease forwards;
    }

    .reveal-right.show {
        animation: fadeRight 1s ease forwards;
    }

    .reveal-item.show {
        animation: fadeUp 0.8s ease forwards;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(25px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeLeft {
        from {
            opacity: 0;
            transform: translateX(-50px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeRight {
        from {
            opacity: 0;
            transform: translateX(50px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .hero-title {
            font-size: 40px;
        }
    }

    /* TITULOS DE SECCIONES */

.section-title h2 {
    color: white !important;
}

.section-title p {
    color: rgba(255,255,255,.9) !important;
}

/* TITULOS DE TARJETAS */

.info-card h4,
.team-card h4,
.feature-rect h5 {
    color: white !important;
}

/* TEXTO DE TARJETAS */

/* =========================
   TARJETAS MODERNAS
========================= */

.info-card,
.team-card,
.feature-rect {
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(15px);
    -webkit-backdrop-filter: blur(15px);

    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 25px;

    padding: 30px;
    height: 100%;

    text-align: center;

    box-shadow:
        0 8px 32px rgba(0,0,0,.20);

    transition: all .4s ease;

    color: white;

    position: relative;
    overflow: hidden;
}

/* EFECTO DE BRILLO */

.info-card::before,
.team-card::before,
.feature-rect::before {
    content: "";
    position: absolute;

    top: -50%;
    left: -50%;

    width: 200%;
    height: 200%;

    background: linear-gradient(
        45deg,
        transparent,
        rgba(255,255,255,.08),
        transparent
    );

    transform: rotate(25deg);
}

/* HOVER */

.info-card:hover,
.team-card:hover,
.feature-rect:hover {
    transform: translateY(-12px);
    box-shadow:
        0 20px 40px rgba(0,0,0,.35);

    border-color: rgba(255,255,255,.5);
}

/* TITULOS */

.info-card h4,
.team-card h4,
.feature-rect h5 {
    color: white;
    font-weight: 700;
    margin-bottom: 15px;
}

/* TEXTOS */

.info-card p,
.team-card p,
.feature-rect p {
    color: rgba(255,255,255,.9);
    line-height: 1.7;
}

/* TITULOS DE SECCION */

.section-title h2 {
    color: white;
    font-weight: 800;
    margin-bottom: 15px;
}

.section-title p {
    color: rgba(255,255,255,.85);
    font-size: 1.1rem;
}

</style>

<!-- =========================
     SCROLL ANIMATION SCRIPT
========================= -->

<script>

    document.addEventListener("DOMContentLoaded", function () {

        const elements = document.querySelectorAll(
            ".reveal-left, .reveal-right, .reveal-item"
        );

        const observer = new IntersectionObserver(entries => {

            entries.forEach(entry => {

                if (entry.isIntersecting) {
                    entry.target.classList.add("show");
                }

            });

        }, {
            threshold: 0.1
        });

        elements.forEach(el => observer.observe(el));

    });

</script>
