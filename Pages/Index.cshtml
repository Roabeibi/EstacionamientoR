@page

@{
    ViewData["Title"] = "Inicio";
}

<div class="hero-section">

    <!-- PARTICLES -->
    <div class="particles"></div>

    <div class="overlay"></div>

    <div class="container position-relative z-1">

        <div class="row align-items-center min-vh-100">

            <!-- TEXTO -->
            <div class="col-lg-6 text-white hero-content reveal-left">

                <span class="badge badge-uv mb-3 p-2 fs-6 reveal-item">
                    Sistema Inteligente
                </span>

                <h1 class="display-3 fw-bold mb-4 reveal-item">
                    Gestor de Cadena de
                    <span>Estacionamientos</span>
                </h1>

                <p class="lead mb-4 reveal-item">
                    Plataforma profesional para administrar vehículos,
                    espacios, reservas, pagos, reportes y monitoreo
                    en tiempo real de estacionamientos inteligentes.
                </p>

                <div class="d-flex gap-3 flex-wrap reveal-item">

                    <a asp-page="/Account/Login"
                       class="btn btn-uv-primary btn-lg px-5 shadow">

                        Iniciar Sesión

                    </a>

                    <a asp-page="/Account/Register"
                       class="btn btn-uv-secondary btn-lg px-5">

                        Registrarse

                    </a>

                </div>

                <!-- FEATURES -->
                <div class="row mt-5 g-4">

                    <div class="col-md-4 reveal-item">
                        <div class="feature-card">
                            🚗
                            <h5>Espacios Inteligentes</h5>
                            <small>Monitoreo en tiempo real</small>
                        </div>
                    </div>

                    <div class="col-md-4 reveal-item">
                        <div class="feature-card">
                            💳
                            <h5>Pagos Automáticos</h5>
                            <small>Control financiero seguro</small>
                        </div>
                    </div>

                    <div class="col-md-4 reveal-item">
                        <div class="feature-card">
                            📊
                            <h5>Reportes</h5>
                            <small>Estadísticas en tiempo real</small>
                        </div>
                    </div>

                </div>

            </div>

            <!-- IMAGEN -->
            <div class="col-lg-6 text-center reveal-right">

                <img src="~/images/parking-banner.jpg"
                     class="img-fluid hero-image shadow-lg" />

            </div>

        </div>

    </div>
</div>
<!-- =========================
     ACERCA DEL PROYECTO
========================= -->

